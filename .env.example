NODE_ENV=production
PORT=8080

# ─── 必要 ───
SESSION_SECRET=                  # 隨機 32 byte hex（node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
ENCRYPTION_KEY=                  # 32 byte hex（64 字元），同上指令生成
ADMIN_USER=admin
ADMIN_PASS_HASH=                 # bcrypt hash（生產必要；開發可用 ADMIN_PASS=changeme123）
ADMIN_PASS=                      # 開發用，生產請改用 ADMIN_PASS_HASH

# ─── DB ───
DB_PATH=./data/cs.db

# ─── AI（至少一個）───
ANTHROPIC_API_KEY=               # Claude API Key，取自 https://console.anthropic.com/
GEMINI_API_KEY=                  # Gemini API Key（fallback），取自 https://aistudio.google.com/
AI_PROVIDER=auto                 # auto / anthropic / gemini
AI_MODEL=claude-haiku-4-5-20251001  # 預設 Haiku 控制成本，可改 claude-sonnet-4-5

# ─── Cookie 安全（自訂域名才設）───
COOKIE_DOMAIN=

# ─── 部署 ───
TRUST_PROXY=1                    # Railway / Nginx reverse proxy 時設 1（讓 req.ip 拿到真實 IP）
GIT_SHA=                         # CI/CD 注入，供 /api/health 顯示版本

# ─── 語音轉文字（LINE 音訊訊息）───
OPENAI_API_KEY=                  # 給 Whisper-1 語音轉文字用，沒設則跳過轉文字
